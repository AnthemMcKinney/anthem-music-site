---
// Small shield/crest motif used as a recurring brand device
const { size = 40, color = "var(--orange)" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 100 110" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <path d="M50 6 L88 18 L88 62 Q88 90 50 104 Q12 90 12 62 L12 18 Z" fill="none" stroke={color} stroke-width="4"/>
  <path d="M30 58 L42 40 L48 47 L56 34 L70 58 Z" fill={color}/>
  <circle cx="50" cy="30" r="8" fill={color} opacity="0.5"/>
</svg>
