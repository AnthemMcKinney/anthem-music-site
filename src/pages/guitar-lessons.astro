---
import Base from '../layouts/Base.astro';

const objectives = [
  { num: "01", title: "Music & guitar fundamentals", items: "Guitar parts, history, and how it fits into the family of instruments. What notes actually are and how they work with rhythm to make music. Tuning any guitar, replacing your own strings, and your first scales (C major and A minor) — the pattern underneath all of it." },
  { num: "02", title: "Chords & rhythm", items: "What chords are and how they work mechanically — then your first chord group: G, Cadd9, D, and Em. These aren't random: they're the I, IV, V, and vi of the key of G, the combination behind thousands of songs. Chord transitions, strumming in 4/4 and 3/4 time, and your first real songs." },
  { num: "03", title: "Songs & picking", items: "More songs, basic fingerpicking, and reading tablature — the point where students start choosing their own material and playing things that sound like actual music, because they are." },
];
---
<Base
  path="/guitar-lessons"
  title="Guitar Lessons in McKinney, TX | Anthem Music"
  description="Guitar lessons in downtown McKinney built on a custom workbook refined by hundreds of students. Acoustic, electric, bass, ukulele, and banjo — all ages, clear progression. Book a consultation.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" style="justify-content:center;">Guitar · Ukulele · Bass · Banjo</span>
      <h1 class="center">Guitar lessons in McKinney</h1>
      <p class="lead mx-auto center">From first chords to lead lines — learn guitar with a clear progression, taught by instructors who teach the why behind every note.</p>
      <div class="center" style="margin-top:1.8rem;"><a href="/schedule" class="btn btn-primary">Book a Consultation</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <h2>A curriculum written by hundreds of students</h2>
      <p>Our guitar program runs on a workbook our founder built the hard way: page by page, over years of real lessons. Every chart and exercise in it exists because actual students asked a question that the standard materials didn't answer. When something didn't land, it got redrawn or thrown out. What's left is a progression that works — refined by the hundreds of students who shaped it.</p>
      <p>That matters because most guitar instruction skips straight to "here's a song, copy it." Students who learn that way can play exactly one thing, usually not well. We build the fundamentals — rhythm, chords, and the patterns woven through all music — so every song you learn makes the next one easier.</p>

      <h2>The beginner path</h2>
      <p>Learning your first songs takes real practice — hands need time to adapt, and timing has to become second nature. We break the journey into three objectives, each building on the last:</p>

      <div class="milestone-list">
        {objectives.map((o) => (
          <div class="milestone">
            <span class="m-period">{o.num}</span>
            <div>
              <h3>{o.title}</h3>
              <p>{o.items}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Where it leads</h2>
      <p>Past the beginner objectives, students move into the full toolkit: barre chords, the CAGED framework, chord progressions across common keys, 16th-note strumming, and — the big one — how to find the key of any song, know which chords belong to it, and play along by ear. That's the point where the guitar stops being a puzzle and starts being yours.</p>

      <div class="feature-grid">
        <div class="feature"><h3>All Ages</h3><p>Kids, teens, adults, homeschoolers, and students with special needs all welcome.</p></div>
        <div class="feature"><h3>All Levels</h3><p>From your very first chord to advanced technique and improvisation.</p></div>
        <div class="feature"><h3>All Styles</h3><p>Rock, blues, folk, worship, classical fingerstyle — whatever moves you. We also teach bass, ukulele, and banjo.</p></div>
      </div>

      <h2>What a first lesson looks like</h2>
      <p>Every new student starts with a consultation: a quick one-on-one assessment where we get a feel for where you are, what instrument and size fits best, and what you want to accomplish. From there we build a clear, personalized plan — no pressure, no guesswork.</p>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div><h2>Start playing guitar</h2><p>Book a consultation and we'll get you set up with the right instructor and a plan to match your goals.</p></div>
      <a href="/schedule" class="btn btn-primary">Book a Consultation</a>
    </div>
  </section>
</Base>

<style>
  .page-hero { background: var(--cream-soft); padding: clamp(2.5rem,5vw,4rem) 0; }
  .page-hero h1 { margin-bottom: 1rem; }
  .narrow { max-width: 760px; }
  .narrow h2 { margin: 2.5rem 0 1rem; }
  .narrow h2:first-child { margin-top: 0; }
  .narrow p { color: var(--gray); margin-bottom: 1.2rem; }
  .milestone-list { display: flex; flex-direction: column; gap: 1rem; margin: 2rem 0; }
  .milestone { display: flex; gap: 1.4rem; background: var(--white); border: 1px solid var(--line); border-radius: 12px; padding: 1.4rem 1.6rem; }
  .m-period { font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; color: var(--orange); white-space: nowrap; }
  .milestone h3 { color: var(--navy); font-size: 1.1rem; margin-bottom: 0.4rem; }
  .milestone p { color: var(--gray); font-size: 0.95rem; margin: 0; }
  .feature-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin: 2.5rem 0; }
  .feature { background: var(--cream-soft); border-radius: 12px; padding: 1.6rem; }
  .feature h3 { color: var(--navy); margin-bottom: 0.5rem; font-size: 1.15rem; }
  .feature p { color: var(--gray); font-size: 0.95rem; margin: 0; }
  .cta-band { background: var(--orange); padding: clamp(2.5rem,5vw,4rem) 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .cta-band h2 { color: var(--white); margin-bottom: 0.5rem; }
  .cta-band p { color: var(--white); opacity: 0.92; max-width: 46ch; }
  .cta-band .btn-primary { background: var(--white); color: var(--orange-dark); }
  .cta-band .btn-primary:hover { background: var(--navy); color: var(--cream); }
  @media (max-width: 700px) { .feature-grid { grid-template-columns: 1fr; } .milestone { flex-direction: column; gap: 0.5rem; } }
</style>
