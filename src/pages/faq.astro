---
import Base from '../layouts/Base.astro';

// Edit answers here — the on-page accordion AND the schema both read from this array,
// so you only update in one place.
const faqs = [
  {
    q: "What ages do you teach?",
    a: "We teach students of nearly every age. Our youngest programs start as early as ages 2–4 (Primary Music) and 4–6 (Kinder Music), which focus on rhythm, movement, and basic musical concepts before a specific instrument. Instrument lessons — guitar, piano, violin, drums, brass, and more — typically begin around ages 6–7 and run through adults. There's no upper limit; we teach plenty of adult beginners."
  },
  {
    q: "How long until my child can play songs?",
    a: "Most beginners are playing simple songs within their first semester. On guitar and drums, students often play their first recognizable songs inside the first 12 weeks. On piano, most students can read and play basic two-hand pieces by the end of a beginner semester. Pace varies by age, practice, and prior experience — but early wins come quickly, which is what keeps students motivated."
  },
  {
    q: "How much should my child practice?",
    a: "Consistency matters more than length. We recommend short daily practice over long occasional sessions: roughly 15–30 minutes a day for piano, 20–40 minutes for guitar, and 20–30 minutes for drums. Even 15 focused minutes most days will move a student forward faster than one long weekend session."
  },
  {
    q: "What instruments do you teach?",
    a: "Guitar, piano, bass, ukulele, banjo, violin, drums, and brass (trumpet, french horn, tuba), plus early-childhood music classes. Each student gets a plan built around their instrument and goals. If you're interested in an instrument you don't see listed, contact us — we'll let you know if we can help or point you to someone who can."
  },
  {
    q: "Do you teach students who learn differently?",
    a: "Yes. We work with students who learn differently, including those on the autism spectrum and students with other learning differences. Our approach is flexible and song-focused when that's what works best — we meet each student where they are and build lessons around what keeps them engaged and confident. Contact us to talk through your student's needs."
  },
  {
    q: "Do you offer band, orchestra, or ensemble programs?",
    a: "We're a private-instruction studio, so we don't run our own band or orchestra — but we're connected to the local music community and refer families to programs that fit. We partner with Texas Homeschool Music (texashomeschoolmusic.org) and other local groups for students interested in concert band, marching band, orchestra, homeschool ensembles, adaptive and therapeutic music, and community performance events. Contact us and we'll help you find the right fit."
  },
  {
    q: "Do you have recitals or performances?",
    a: "Yes. We hold semester-end recitals and performance opportunities. They're optional but encouraged — performing is one of the best ways to build confidence and give students a real goal to work toward."
  },
  {
    q: "Where are you located?",
    a: "We're in downtown McKinney at 209 N Tennessee St, McKinney, TX 75069, serving McKinney, Frisco, Allen, Prosper, and the surrounding Collin County area."
  },
  {
    q: "How do I get started?",
    a: "The easiest way is to book a lesson through our Schedule page, or call us at 469-500-9863. We'll match your student with the right instructor and get a plan started."
  }
];
---
<Base
  path="/faq"
  title="FAQ | Anthem Music Lessons in McKinney, TX"
  description="Common questions about music lessons at Anthem Music in downtown McKinney — ages, practice, instruments, adaptive lessons, band and orchestra referrals, recitals, and how to get started."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })}
  />

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" style="justify-content:center;">Questions &amp; Answers</span>
      <h1 class="center">Frequently asked questions</h1>
      <p class="lead mx-auto center">Everything parents and students ask most. Don't see yours? <a href="/contact">Contact us</a> — we're glad to help.</p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="faq-answer"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <h2>Ready to start?</h2>
        <p>Book a lesson or reach out with any question — we'll help you find the right fit.</p>
      </div>
      <a href="/schedule" class="btn btn-primary">Book a Lesson</a>
    </div>
  </section>
</Base>

<style>
  .page-hero { background: var(--cream-soft); padding: clamp(2.5rem,5vw,4rem) 0; }
  .page-hero h1 { margin-bottom: 1rem; }
  .narrow { max-width: 760px; }

  .faq-list { display: flex; flex-direction: column; gap: 0.9rem; }
  .faq-item {
    background: var(--cream-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .faq-item summary {
    cursor: pointer;
    list-style: none;
    padding: 1.15rem 1.4rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--orange);
    line-height: 1;
    transition: transform .2s;
  }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item summary:hover { color: var(--orange); }
  .faq-answer { padding: 0 1.4rem 1.3rem; }
  .faq-answer p { color: var(--gray); margin: 0; }

  .cta-band { background: var(--orange); padding: clamp(2.5rem,5vw,4rem) 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .cta-band h2 { color: var(--white); margin-bottom: 0.5rem; }
  .cta-band p { color: var(--white); opacity: 0.92; max-width: 46ch; }
  .cta-band .btn-primary { background: var(--white); color: var(--orange-dark); }
  .cta-band .btn-primary:hover { background: var(--navy); color: var(--cream); }
</style>
