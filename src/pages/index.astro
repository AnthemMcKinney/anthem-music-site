---
import Base from '../layouts/Base.astro';
import Shield from '../components/Shield.astro';
import Reviews from '../components/Reviews.astro';

const lessons = [
  { name: "Guitar & Ukulele", icon: "guitar", href: "/guitar-lessons", blurb: "From first chords to lead lines — guitar, bass, ukulele, and banjo for every age." },
  { name: "Piano", icon: "piano", href: "/piano-lessons", blurb: "Classical foundation, modern application. Reading, technique, and playing you'll actually enjoy." },
  { name: "Violin", icon: "glyph", glyph: "𝄞", href: "/programs", blurb: "Suzuki-informed strings instruction for young beginners through advancing players." },
  { name: "Drums & Percussion", icon: "drums", href: "/programs", blurb: "Timing, technique, and groove — from first beats to full-kit control." },
  { name: "Brass", icon: "glyph", glyph: "♬", href: "/programs", blurb: "Private lessons on trumpet, french horn, and tuba — anything with three valves. Build tone, range, and technique." },
  { name: "Kinder Music", icon: "school", href: "/programs", blurb: "Music core concepts for ages 2–6. Rhythm, listening, and joyful first exposure." },
];

// Tabler outline icons (MIT licensed), inlined — no external dependency.
const icons: Record<string, string> = {
  guitar: '<path d="M16 18.5c2 -2.5 4 -6.5 4 -10.5c0 -2.946 -2.084 -4.157 -4.204 -4.654c-.864 -.23 -2.13 -.346 -3.796 -.346c-1.667 0 -2.932 .115 -3.796 .346c-2.12 .497 -4.204 1.708 -4.204 4.654c0 3.312 2 8 4 10.5c.297 .37 .618 .731 .963 1.081l.354 .347a3.9 3.9 0 0 0 5.364 0a14.05 14.05 0 0 0 1.319 -1.428"/>',
  piano: '<path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10"/><path d="M9 19v-6"/><path d="M8 5v8h2v-8"/><path d="M15 19v-6"/><path d="M14 5v8h2v-8"/>',
  drums: '<path d="M3 17a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"/><path d="M13 17a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"/><path d="M9 17v-13h10v13"/><path d="M9 8h10"/>',
  school: '<path d="M22 9l-10 -4l-10 4l10 4l10 -4v6"/><path d="M6 10.6v5.4a6 3 0 0 0 12 0v-5.4"/>',
};

const instructors = [
  { name: "Dan Brady", role: "Owner · Guitar & Piano", img: "/instructors/dan.jpg" },
  { name: "Britton Lowenthal", role: "Piano · Trumpet", img: "/instructors/britton.jpg" },
  { name: "Christine Dao", role: "Violin · Piano", img: "/instructors/christine.jpg" },
];
---
<Base path="/">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Downtown McKinney · Music Lessons for All Ages</span>
        <h1>Where musicians are <em>formed</em>,<br class="h1-break" /> not just taught.</h1>
        <p class="lead">Guitar, piano, violin, drums, and brass for all ages — rooted in craft, mentorship, and a genuine love of music. Serious about musicianship, warm enough for the whole family.</p>
        <div class="hero-actions">
          <a href="/schedule" class="btn btn-primary">Book a Lesson</a>
          <a href="/#lessons" class="btn btn-outline">Explore Lessons</a>
        </div>
        <div class="hero-trust">
          <span>★★★★★</span>
          <span>Trusted by McKinney &amp; Frisco families</span>
        </div>
      </div>
      <div class="hero-image-wrap">
        <img src="/images/hero.jpg" alt="The Anthem Music studio in downtown McKinney — guitars, drums, and bright open windows" width="1600" height="1200" />
        <div class="hero-badge">
          <Shield size={28} color="var(--orange)" />
          <div>
            <strong>15+ years</strong>
            <span>teaching experience</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="lessons">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">What We Teach</span>
        <h2>Lessons for every age and instrument</h2>
        <p class="lead mx-auto center">Every student is met where they are. No rigid curriculum — instruction is built around each player's goals, pace, and the way they learn best.</p>
      </div>
      <div class="lessons-grid">
        {lessons.map((l) => (
          <a href={l.href} class="lesson-card">
            <span class="lesson-icon" aria-hidden="true">
              {l.icon === "glyph" ? (
                <span class="lesson-glyph">{l.glyph}</span>
              ) : (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={icons[l.icon]} />
              )}
            </span>
            <h3>{l.name}</h3>
            <p>{l.blurb}</p>
            <span class="lesson-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Reviews />

  <section class="section philosophy on-navy">
    <div class="container philosophy-inner">
      <div class="philosophy-copy">
        <span class="eyebrow">The Anthem Approach</span>
        <h2>We teach the <em>why</em>, not just the notes.</h2>
        <p>Most programs hand a student a song, walk them through it note by note, and call it a lesson. The problem: that student can now play exactly one thing — usually not very well — and they're stuck the moment they step outside it.</p>
        <p>We teach differently. As students move through copying, creating, and innovating, we teach the <em>why</em> behind every concept — why certain chords always show up together, why a scale pattern fits one moment and not the next, why the instrument is built the way it is. That understanding is the difference between memorizing music and actually playing it.</p>
        <p>The goal isn't just to do music. It's to understand it well enough to play by ear, sit in with anyone, and make something your own. Learn to love music, and the playing takes care of itself.</p>
        <a href="/about" class="btn btn-cream">Read Our Story</a>
      </div>
      <div class="philosophy-media">
        <img src="/images/teaching-kids.jpg" alt="Dan Brady teaching a group of young students at Anthem Music" loading="lazy" width="900" height="675" />
        <div class="philosophy-steps">
          <div class="pstep"><span>01</span><div><strong>Copy</strong><p>Master the mechanics and techniques that build real coordination.</p></div></div>
          <div class="pstep"><span>02</span><div><strong>Create</strong><p>Learn the why behind the music — then use it to play what's your own.</p></div></div>
          <div class="pstep"><span>03</span><div><strong>Innovate</strong><p>With the fundamentals understood, making new music comes naturally.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Our Team</span>
        <h2>Instructors who mentor, not just instruct</h2>
        <p class="lead mx-auto center">Our teachers bring decades of combined experience across performance, classroom instruction, and real musicianship — and they genuinely care about the students they teach.</p>
      </div>
      <div class="instructor-grid">
        {instructors.map((i) => (
          <div class="instructor-card">
            <div class="instructor-photo">
              <img src={i.img} alt={i.name} loading="lazy" width="300" height="340" />
            </div>
            <h3>{i.name}</h3>
            <span class="instructor-role">{i.role}</span>
          </div>
        ))}
      </div>
      <div class="center" style="margin-top:2.5rem;">
        <a href="/instructors" class="btn btn-outline">Meet the Full Team</a>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <h2>Ready to start?</h2>
        <p>Book a lesson and we'll help you find the right instrument, the right instructor, and a clear plan to get going — no pressure, just a good first step.</p>
      </div>
      <a href="/schedule" class="btn btn-primary">Book a Lesson</a>
    </div>
  </section>
</Base>

<style>
  .hero { background: linear-gradient(180deg, var(--cream-soft) 0%, var(--white) 100%); padding: clamp(2.5rem, 6vw, 5rem) 0 clamp(3rem, 6vw, 5rem); }
  /* Asymmetric split: image dominant (right ~58%), copy left (~42%) */
  .hero-grid { display: grid; grid-template-columns: 42fr 58fr; gap: clamp(1.5rem, 3.5vw, 3rem); align-items: center; }
  .hero-copy h1 { font-size: clamp(2.1rem, 4.4vw, 3.3rem); margin-bottom: 1.5rem; }
  .hero-copy h1 em { color: var(--orange); font-style: italic; }
  .h1-break { display: inline; }
  .hero-copy .lead { max-width: 50ch; }
  .hero-actions { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }
  .hero-trust { display: flex; align-items: center; gap: 0.7rem; margin-top: 2rem; font-size: 0.92rem; color: var(--gray); }
  .hero-trust span:first-child { color: var(--orange); letter-spacing: 2px; }
  .hero-image-wrap { position: relative; }
  .hero-image-wrap img { border-radius: 16px; width: 100%; height: auto; aspect-ratio: 4/3; object-fit: cover; box-shadow: 0 20px 50px rgba(13,31,60,.18); display: block; }
  .hero-badge { position: absolute; bottom: -18px; left: -18px; background: var(--white); border-radius: 12px; padding: 0.85rem 1.15rem; display: flex; align-items: center; gap: 0.7rem; box-shadow: 0 12px 30px rgba(13,31,60,.15); }
  .hero-badge strong { display: block; font-family: var(--font-display); color: var(--navy); font-size: 1.05rem; }
  .hero-badge span { font-size: 0.78rem; color: var(--gray); }

  .section-head { text-align: center; max-width: 640px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); }
  .section-head .eyebrow { justify-content: center; }
  .section-head h2 { margin-bottom: 1rem; }

  .lessons-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .lesson-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 2rem; transition: transform .2s, box-shadow .2s, border-color .2s; display: flex; flex-direction: column; }
  .lesson-card:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(13,31,60,.1); border-color: transparent; }
  .lesson-icon { width: 48px; height: 48px; border-radius: 10px; background: var(--cream); color: var(--orange); display: flex; align-items: center; justify-content: center; margin-bottom: 1.2rem; }
  .lesson-glyph { font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; color: var(--navy); line-height: 1; }
  .lesson-card h3 { color: var(--navy); margin-bottom: 0.6rem; }
  .lesson-card p { color: var(--gray); font-size: 0.95rem; flex: 1; }
  .lesson-link { color: var(--orange); font-weight: 600; font-size: 0.92rem; margin-top: 1rem; }

  .philosophy { background: var(--navy); }
  .philosophy-inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .philosophy-copy p { color: var(--cream); opacity: 0.82; margin-bottom: 1.2rem; }
  .philosophy-copy p em { color: var(--orange); font-style: italic; }
  .philosophy-copy h2 { margin-bottom: 1.3rem; }
  .philosophy-media { display: flex; flex-direction: column; gap: 1.2rem; }
  .philosophy-media > img { border-radius: 14px; width: 100%; height: auto; object-fit: cover; box-shadow: 0 16px 40px rgba(0,0,0,.3); }
  .philosophy-steps { display: flex; flex-direction: column; gap: 0.9rem; }
  .pstep { display: flex; gap: 1.2rem; background: var(--navy-light); border-radius: 12px; padding: 1.3rem 1.5rem; }
  .pstep span { font-family: var(--font-display); font-size: 1.6rem; font-weight: 600; color: var(--orange); line-height: 1; }
  .pstep strong { color: var(--cream); font-family: var(--font-display); font-size: 1.2rem; display: block; margin-bottom: 0.3rem; }
  .pstep p { color: var(--cream); opacity: 0.75; font-size: 0.9rem; margin: 0; }

  .instructor-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .instructor-card { text-align: center; }
  .instructor-photo { border-radius: 14px; overflow: hidden; margin-bottom: 1rem; aspect-ratio: 3/3.4; background: var(--cream); }
  .instructor-photo img { width: 100%; height: 100%; object-fit: cover; }
  .instructor-card h3 { color: var(--navy); font-size: 1.25rem; margin-bottom: 0.2rem; }
  .instructor-role { color: var(--orange); font-size: 0.88rem; font-weight: 600; }

  .cta-band { background: var(--orange); padding: clamp(2.5rem, 5vw, 4rem) 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .cta-band h2 { color: var(--white); margin-bottom: 0.5rem; }
  .cta-band p { color: var(--white); opacity: 0.92; max-width: 46ch; }
  .cta-band .btn-primary { background: var(--white); color: var(--orange-dark); }
  .cta-band .btn-primary:hover { background: var(--navy); color: var(--cream); }

  @media (max-width: 980px) {
    .lessons-grid { grid-template-columns: repeat(2, 1fr); }
    .instructor-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 860px) {
    /* Hero stacks: copy on top, image below — clean on phones */
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .h1-break { display: none; }
    .hero-badge { left: auto; right: 16px; }
  }
  @media (max-width: 780px) {
    .philosophy-inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .lessons-grid { grid-template-columns: 1fr; }
    .instructor-grid { grid-template-columns: 1fr; }
  }
</style>
