---
import Base from '../layouts/Base.astro';

const milestones = [
  { period: "Months 1–3", title: "Setup and first notes", items: "Instrument parts and tuning, violin and bow hold, posture, plucking and bowing open strings, first note reading, and simple one-line melodies like Hot Cross Buns and Twinkle. Learning to listen and match pitch from day one." },
  { period: "Months 4–6", title: "Expanding range and reading", items: "Second and third fingers on the A and D strings, first-position reading across two to three strings, D and A major scales, slurs and simple dynamics, and counting with a metronome." },
  { period: "Months 7–9", title: "Full melodies and ensemble readiness", items: "Full first-position fingerboard work, string crossing and slurred bowing, longer pieces with repeats, duet playing with teacher or backing track, and understanding song form." },
  { period: "Months 10–12", title: "Musical confidence", items: "Performing full songs from memory or sheet music, expressive bowing and phrasing, simple double stops, transposing melodies, beginning improvisation, and preparing for recital." },
];
---
<Base
  path="/violin-lessons"
  title="Violin Lessons in McKinney, TX | Anthem Music"
  description="Beginner violin lessons in downtown McKinney combining classical technique with real-world musicianship. Clear 12-month milestones, Suzuki-informed instruction, all ages. Book a consultation.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" style="justify-content:center;">Violin · From First Bow to Full Songs</span>
      <h1 class="center">Violin lessons in McKinney</h1>
      <p class="lead mx-auto center">Classical technique meets real-world musicianship - building confident, expressive players who can read, play by ear, and make music their own.</p>
      <div class="center" style="margin-top:1.8rem;"><a href="/schedule" class="btn btn-primary">Book a Consultation</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <h2>Technique first - but never technique only</h2>
      <p>Our violin program is built for players headed anywhere: orchestra, solo performance, or modern music. We use traditional violin methods to develop strong technique, proper form, and note-reading - and, like everything at Anthem, we teach how music actually works, so students can play by ear, improvise, and create rather than only reproduce what's on the page.</p>
      <p>Students start with the fundamentals: posture, bow control, and pitch accuracy. From there we blend in real music - folk melodies, orchestral pieces, or songs the student picks - so lessons stay engaging and goal-oriented instead of drill-driven.</p>

      <div class="feature-grid">
        <div class="feature"><h3>Technique &amp; Posture</h3><p>Stance, bow hold, and left-hand positioning, with finger tapes as early visual guides and bowing exercises that build control and tone.</p></div>
        <div class="feature"><h3>Reading &amp; Ear Training</h3><p>Notes on the treble clef, accurate rhythm, and ear development through interval matching and call-and-response playing.</p></div>
        <div class="feature"><h3>Real Pieces</h3><p>Folk melodies, beginner classical works, and simplified pop themes - with emphasis on phrasing, expression, and consistency.</p></div>
      </div>

      <h2>A clear first-year path</h2>
      <p>Every student moves at their own pace, but parents deserve to know what progress looks like. This is the arc most beginners follow:</p>

      <div class="milestone-list">
        {milestones.map((m) => (
          <div class="milestone">
            <span class="m-period">{m.period}</span>
            <div>
              <h3>{m.title}</h3>
              <p>{m.items}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Where most students land by month 12</h2>
      <p>Correct hold and posture, first-position reading across all four strings, basic rhythms, melodies like Ode to Joy and early Suzuki pieces, D and A major scales with proper intonation, steady tempo with a metronome, and duet or small-ensemble playing. Many begin simple scale-based improvisation - the first step toward making music that's theirs.</p>

      <h2>Getting started</h2>
      <p>Every new student begins with a consultation: a one-on-one assessment where we check instrument sizing (especially important for young violinists), get a feel for goals and experience, and build a clear plan. No pressure - just a good first step.</p>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div><h2>Start violin the right way</h2><p>Book a consultation and we'll handle sizing, instructor fit, and a plan that matches your goals.</p></div>
      <a href="/schedule" class="btn btn-primary">Book a Consultation</a>
    </div>
  </section>
</Base>

<style>
  .page-hero { background: var(--cream-soft); padding: clamp(2.5rem,5vw,4rem) 0; }
  .page-hero h1 { margin-bottom: 1rem; }
  .narrow { max-width: 760px; }
  .narrow h2 { margin: 2.5rem 0 1rem; }
  .narrow h2:first-child { margin-top: 0; }
  .narrow p { color: var(--gray); margin-bottom: 1.2rem; }
  .feature-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin: 2.5rem 0; }
  .feature { background: var(--cream-soft); border-radius: 12px; padding: 1.6rem; }
  .feature h3 { color: var(--navy); margin-bottom: 0.5rem; font-size: 1.15rem; }
  .feature p { color: var(--gray); font-size: 0.95rem; margin: 0; }
  .milestone-list { display: flex; flex-direction: column; gap: 1rem; margin: 2rem 0; }
  .milestone { display: flex; gap: 1.4rem; background: var(--white); border: 1px solid var(--line); border-radius: 12px; padding: 1.4rem 1.6rem; }
  .m-period { font-family: var(--font-display); font-weight: 600; color: var(--orange); white-space: nowrap; min-width: 7.5rem; }
  .milestone h3 { color: var(--navy); font-size: 1.1rem; margin-bottom: 0.4rem; }
  .milestone p { color: var(--gray); font-size: 0.95rem; margin: 0; }
  .cta-band { background: var(--orange); padding: clamp(2.5rem,5vw,4rem) 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .cta-band h2 { color: var(--white); margin-bottom: 0.5rem; }
  .cta-band p { color: var(--white); opacity: 0.92; max-width: 46ch; }
  .cta-band .btn-primary { background: var(--white); color: var(--orange-dark); }
  .cta-band .btn-primary:hover { background: var(--navy); color: var(--cream); }
  @media (max-width: 700px) { .feature-grid { grid-template-columns: 1fr; } .milestone { flex-direction: column; gap: 0.5rem; } }
</style>
