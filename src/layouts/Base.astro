---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = "Anthem Music | Music Lessons in Downtown McKinney, TX",
  description = "Guitar, piano, violin, drums, and brass lessons for all ages in downtown McKinney. A family-centered music studio rooted in craft, mentorship, and real musicianship.",
  path = "",
} = Astro.props;

const site = "https://anthemmusic.net";
const canonical = site + path;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={`${site}/images/og-image.jpg`} />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- LocalBusiness structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MusicSchool",
    "name": "Anthem Music LLC",
    "description": description,
    "url": site,
    "telephone": "+1-469-500-9863",
    "email": "danbrady@anthemmusic.net",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "209 N Tennessee St",
      "addressLocality": "McKinney",
      "addressRegion": "TX",
      "postalCode": "75069",
      "addressCountry": "US"
    },
    "areaServed": ["McKinney", "Frisco", "Allen", "Prosper", "Collin County"],
    "priceRange": "$$"
  })} />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
  body { display: flex; flex-direction: column; min-height: 100vh; }
  main { flex: 1; }
</style>
