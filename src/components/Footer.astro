---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <span class="footer-logo">Anthem<span>Music</span></span>
      <p>A downtown McKinney music studio — where students of all ages are trained, encouraged, and challenged to grow in real musicianship.</p>
      <div class="footer-social" aria-label="Social links">
        <a href="https://www.facebook.com/anthemmusicmckinney" aria-label="Facebook">Facebook</a>
        <a href="https://www.instagram.com/anthemmusicmckinney" aria-label="Instagram">Instagram</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Lessons</h4>
      <a href="/guitar-lessons">Guitar &amp; Ukulele</a>
      <a href="/piano-lessons">Piano</a>
      <a href="/programs">Drums &amp; Percussion</a>
      <a href="/programs">Violin</a>
      <a href="/programs">Band &amp; Orchestra</a>
      <a href="/programs">Kinder Music</a>
    </div>

    <div class="footer-col">
      <h4>Studio</h4>
      <a href="/instructors">Instructors</a>
      <a href="/about">About Us</a>
      <a href="/schedule">Book a Lesson</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Visit</h4>
      <p class="footer-contact">
        209 N Tennessee St<br/>
        McKinney, TX 75069<br/>
        <a href="tel:+14695009863">(469) 500-9863</a><br/>
        <a href="mailto:danbrady@anthemmusic.net">danbrady@anthemmusic.net</a>
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <span>© {year} Anthem Music LLC. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--navy); color: var(--cream); margin-top: auto; }
  .footer-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr 1.3fr; gap: 2.5rem;
    padding-top: 4rem; padding-bottom: 3rem;
  }
  .footer-logo {
    font-family: var(--font-display); font-weight: 600; font-size: 1.5rem;
    color: var(--cream); display: block; margin-bottom: 1rem;
  }
  .footer-logo span { color: var(--orange); margin-left: 0.3rem; }
  .footer-brand p { color: var(--gray-light); font-size: 0.95rem; max-width: 34ch; }
  .footer-social { display: flex; gap: 1.2rem; margin-top: 1.2rem; }
  .footer-social a { color: var(--cream); font-size: 0.9rem; font-weight: 500; }
  .footer-social a:hover { color: var(--orange); }
  .footer-col h4 { color: var(--cream); font-size: 1.05rem; margin-bottom: 1rem; }
  .footer-col a { display: block; color: var(--gray-light); font-size: 0.93rem; padding: 0.3rem 0; }
  .footer-col a:hover { color: var(--orange); }
  .footer-contact { color: var(--gray-light); font-size: 0.93rem; line-height: 1.9; }
  .footer-contact a { color: var(--gray-light); }
  .footer-contact a:hover { color: var(--orange); }
  .footer-bottom { border-top: 1px solid var(--navy-light); padding: 1.5rem 0; }
  .footer-bottom span { color: var(--gray-light); font-size: 0.85rem; }

  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 500px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
