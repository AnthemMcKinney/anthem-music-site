---
const nav = [
  { label: "Lessons", href: "/#lessons" },
  { label: "Instructors", href: "/instructors" },
  { label: "About", href: "/about" },
  { label: "Blog", href: "/blog" },
  { label: "Schedule", href: "/schedule" },
  { label: "Contact", href: "/contact" },
];
const portalUrl = "https://app.mymusicstaff.com/Default.aspx";
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Anthem Music home">
      <img src="/anthem-logo.svg" alt="Anthem Music" class="brand-logo" width="44" height="48" />
      <span class="brand-text">Anthem<span class="brand-sub">Music</span></span>
    </a>

    <nav class="nav-desktop" aria-label="Main navigation">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={portalUrl} class="btn parent-login" target="_blank" rel="noopener noreferrer">Student Login</a>
      <a href="/schedule" class="btn btn-primary nav-cta">Book a Lesson</a>
    </nav>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="nav-mobile" id="navMobile" aria-label="Mobile navigation">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href={portalUrl} class="btn parent-login" target="_blank" rel="noopener noreferrer">Student Login</a>
    <a href="/schedule" class="btn btn-primary">Book a Lesson</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 74px;
  }
  .brand { display: flex; align-items: center; gap: 0.6rem; }
  .brand-logo { height: 48px; width: auto; }
  .brand-text {
    font-family: var(--font-display); font-weight: 600; font-size: 1.5rem;
    color: var(--navy); line-height: 1; letter-spacing: -0.02em;
  }
  .brand-sub { color: var(--orange); margin-left: 0.3rem; }
  .nav-desktop { display: flex; align-items: center; gap: 1.4rem; }
  .nav-desktop > a:not(.nav-cta):not(.parent-login) {
    color: var(--navy); font-weight: 500; font-size: 0.98rem;
    position: relative;
  }
  .nav-desktop > a:not(.nav-cta):not(.parent-login):hover { color: var(--orange); }
  .nav-cta { padding: 0.6rem 1.3rem; font-size: 0.95rem; }

  /* Parent Login — deliberately yellow, outside the navy/orange brand palette,
     so it reads as a utility/portal element without diluting the brand. */
  .parent-login {
    background: #F6C544;
    color: var(--navy);
    padding: 0.6rem 1.2rem;
    font-size: 0.9rem;
    font-weight: 600;
    border: 2px solid transparent;
  }
  .parent-login:hover {
    background: #E9B52E;
    color: var(--navy);
    transform: translateY(-2px);
  }

  .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; }
  .nav-toggle span { width: 26px; height: 2px; background: var(--navy); transition: .3s; }
  .nav-mobile { display: none; flex-direction: column; padding: 1rem var(--pad) 1.5rem; gap: 0.5rem; border-top: 1px solid var(--line); background: var(--white); }
  .nav-mobile a:not(.btn) { color: var(--navy); font-weight: 500; padding: 0.6rem 0; }
  .nav-mobile.open { display: flex; }

  @media (max-width: 1120px) {
    .nav-desktop { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.getElementById('navToggle');
  const mobile = document.getElementById('navMobile');
  toggle?.addEventListener('click', () => {
    const open = mobile?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
